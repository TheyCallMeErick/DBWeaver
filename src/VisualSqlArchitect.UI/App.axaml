<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Design tokens first -->
        <ResourceInclude Source="avares://VisualSqlArchitect.UI/Assets/Themes/DesignTokens.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <!-- Fluent Dark base -->
    <FluentTheme/>

    <!-- DataGrid theme (required, otherwise DataGrid renders invisible) -->
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

    <!-- Material Icons -->
    <mi:MaterialIconStyles/>

    <!-- Global overrides -->
    <StyleInclude Source="avares://VisualSqlArchitect.UI/Assets/Themes/AppStyles.axaml"/>
  </Application.Styles>

</Application>
