<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.SqlImporterOverlay"
             x:DataType="vm:SqlImporterViewModel">

  <UserControl.Styles>
    <Style Selector="Button.sql-action">
      <Setter Property="Background"    Value="#0D0F14"/>
      <Setter Property="BorderBrush"   Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"    Value="#8B95A8"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="10,5"/>
      <Setter Property="FontSize"      Value="12"/>
      <Setter Property="Cursor"        Value="Hand"/>
    </Style>
    <Style Selector="Button.sql-action:pointerover">
      <Setter Property="Background" Value="#131720"/>
      <Setter Property="Foreground" Value="#E8EAED"/>
    </Style>
    <Style Selector="Button.import-btn">
      <Setter Property="Background"    Value="#0F2A1A"/>
      <Setter Property="BorderBrush"   Value="#14B8A6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"    Value="#14B8A6"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="14,6"/>
      <Setter Property="FontSize"      Value="12"/>
      <Setter Property="FontWeight"    Value="SemiBold"/>
      <Setter Property="Cursor"        Value="Hand"/>
    </Style>
    <Style Selector="Button.import-btn:pointerover">
      <Setter Property="Background" Value="#0F3A22"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Card ═══════════════════════════════════════════════════════════════ -->
  <Border Width="560"
          CornerRadius="14"
          Background="#0D0F14"
          BorderBrush="#1E2335"
          BorderThickness="1"
          BoxShadow="0 12 60 0 #A0000000, 0 2 8 0 #50000000">

    <StackPanel>

      <!-- ── Header ────────────────────────────────────────────────────────── -->
      <Border Padding="16,14"
              Background="#13161F"
              CornerRadius="14,14,0,0"
              BorderBrush="#1E2335"
              BorderThickness="0,0,0,1">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Icon + title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="30" Height="30" CornerRadius="8" Background="#0F2A1A">
              <mi:MaterialIcon Kind="CodeBrackets"
                               Width="16" Height="16"
                               Foreground="#14B8A6"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="Import SQL to Graph"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#E8EAED"/>
              <TextBlock Text="Paste a SELECT statement — nodes are created automatically"
                         FontSize="10"
                         Foreground="#4A5568"/>
            </StackPanel>
          </StackPanel>

          <!-- Close button -->
          <Button Grid.Column="2"
                  Classes="sql-action"
                  Name="CloseBtn"
                  AutomationProperties.Name="Close SQL importer"
                  Padding="7,5">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- ── SQL input ──────────────────────────────────────────────────────── -->
      <Border Padding="14,12">
        <StackPanel Spacing="8">
          <TextBlock Text="SQL STATEMENT"
                     FontSize="9"
                     FontWeight="Bold"
                     Foreground="#4A5568"
                     LetterSpacing="1.5"/>
          <TextBox Text="{Binding SqlInput, Mode=TwoWay}"
                   AcceptsReturn="True"
                   MinHeight="120"
                   MaxHeight="200"
                   FontFamily="Consolas,monospace"
                   FontSize="12"
                   Foreground="#14B8A6"
                   Background="#070B10"
                   BorderBrush="#252C3F"
                   BorderThickness="1"
                   CornerRadius="8"
                   Padding="10,8"
                   Watermark="SELECT id, name FROM public.orders WHERE status = 'ACTIVE' LIMIT 100"
                   TextWrapping="Wrap"
                   AcceptsTab="False"
                   Name="SqlInputBox">
            <TextBox.Styles>
              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                <Setter Property="BorderBrush" Value="#14B8A6"/>
              </Style>
            </TextBox.Styles>
          </TextBox>

          <!-- Supported syntax hint -->
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Supported: "
                       FontSize="10"
                       Foreground="#4A5568"
                       VerticalAlignment="Center"/>
            <Border Background="#131C14" CornerRadius="3" Padding="4,1" Margin="2,0">
              <TextBlock Text="SELECT" FontSize="9" FontFamily="Consolas,monospace" Foreground="#34D399"/>
            </Border>
            <Border Background="#131C14" CornerRadius="3" Padding="4,1" Margin="2,0">
              <TextBlock Text="FROM" FontSize="9" FontFamily="Consolas,monospace" Foreground="#34D399"/>
            </Border>
            <Border Background="#131C14" CornerRadius="3" Padding="4,1" Margin="2,0">
              <TextBlock Text="JOIN" FontSize="9" FontFamily="Consolas,monospace" Foreground="#34D399"/>
            </Border>
            <Border Background="#131C14" CornerRadius="3" Padding="4,1" Margin="2,0">
              <TextBlock Text="WHERE" FontSize="9" FontFamily="Consolas,monospace" Foreground="#34D399"/>
            </Border>
            <Border Background="#131C14" CornerRadius="3" Padding="4,1" Margin="2,0">
              <TextBlock Text="LIMIT" FontSize="9" FontFamily="Consolas,monospace" Foreground="#34D399"/>
            </Border>
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ── Action bar ─────────────────────────────────────────────────────── -->
      <Border Padding="14,0,14,12">
        <Grid ColumnDefinitions="*,Auto">

          <!-- Status message -->
          <TextBlock Grid.Column="0"
                     Text="{Binding StatusMessage}"
                     FontSize="11"
                     Foreground="#4A5568"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <!-- Import button -->
          <Button Grid.Column="1"
                  Classes="import-btn"
                  Name="ImportBtn"
                  IsEnabled="{Binding !IsImporting}"
                  AutomationProperties.Name="Import SQL">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <mi:MaterialIcon Kind="ArrowRightBold" Width="14" Height="14"/>
              <TextBlock Text="Import"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- ── Conversion report ──────────────────────────────────────────────── -->
      <Border Padding="14,0,14,14"
              IsVisible="{Binding HasReport}">
        <StackPanel Spacing="6">
          <Border Height="1" Background="#1E2335"/>
          <TextBlock Text="CONVERSION REPORT"
                     FontSize="9"
                     FontWeight="Bold"
                     Foreground="#4A5568"
                     LetterSpacing="1.5"
                     Margin="0,6,0,2"/>
          <ItemsControl ItemsSource="{Binding Report}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ImportReportItem">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                  <!-- Status icon -->
                  <TextBlock Grid.Column="0"
                             Text="{Binding StatusIcon}"
                             FontFamily="Consolas,monospace"
                             FontSize="11"
                             Foreground="{Binding StatusColor}"
                             VerticalAlignment="Center"
                             Width="16"/>
                  <!-- Label -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Label}"
                             FontSize="11"
                             FontFamily="Consolas,monospace"
                             Foreground="#8B95A8"
                             VerticalAlignment="Center"
                             Margin="4,0"/>
                  <!-- Note -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding Note}"
                             FontSize="10"
                             Foreground="#4A5568"
                             VerticalAlignment="Center"
                             IsVisible="{Binding Note, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
