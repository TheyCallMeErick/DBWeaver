<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             x:Class="VisualSqlArchitect.UI.Controls.AutoJoinOverlay"
             x:DataType="vm:AutoJoinOverlayViewModel">

  <UserControl.Styles>

    <!-- Card -->
    <Style Selector="Border.join-card">
      <Setter Property="Background"    Value="#111520"/>
      <Setter Property="BorderBrush"   Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"  Value="10"/>
      <Setter Property="Padding"       Value="12,10"/>
      <Setter Property="Margin"        Value="0,4"/>
    </Style>

    <!-- Accept button -->
    <Style Selector="Button.accept-btn">
      <Setter Property="Background"     Value="#0F2040"/>
      <Setter Property="BorderBrush"    Value="#1E3A60"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"     Value="#60A5FA"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="CornerRadius"   Value="6"/>
      <Setter Property="Padding"        Value="8,4"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.accept-btn:pointerover">
      <Setter Property="Background" Value="#162540"/>
    </Style>

    <!-- Dismiss button -->
    <Style Selector="Button.dismiss-btn">
      <Setter Property="Background"     Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"     Value="#4A5568"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="Padding"        Value="6,4"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.dismiss-btn:pointerover">
      <Setter Property="Foreground" Value="#E8EAED"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Overlay panel ══════════════════════════════════════════════════════ -->
  <Border MaxWidth="380"
          Background="#0D0F14"
          BorderBrush="#252C3F"
          BorderThickness="1"
          CornerRadius="12"
          BoxShadow="0 8 40 0 #80000000">

    <StackPanel>

      <!-- ── Header ───────────────────────────────────────────────────────── -->
      <Border Background="#0B0D12"
              CornerRadius="12,12,0,0"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto,Auto">

          <!-- Sparkle icon -->
          <Border Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="6"
                  Background="#0F1A30"
                  BorderBrush="#1E3A60"
                  BorderThickness="1"
                  Margin="0,0,8,0">
            <TextBlock Text="✦"
                       FontSize="11"
                       Foreground="#60A5FA"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="Auto-Join Suggestions"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#E8EAED"/>
            <TextBlock Text="{Binding Title}"
                       FontSize="10"
                       Foreground="#4A5568"/>
          </StackPanel>

          <!-- Accept All -->
          <Button Grid.Column="2"
                  Classes="accept-btn"
                  Content="Accept All"
                  Margin="0,0,4,0"
                  Name="AcceptAllBtn"/>

          <!-- Close All -->
          <Button Grid.Column="3"
                  Classes="dismiss-btn"
                  Content="✕"
                  FontSize="13"
                  Name="DismissAllBtn"/>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Suggestion cards ──────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="360"
                    Margin="8,6"
                    HorizontalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding Cards}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:JoinSuggestionCardViewModel">

              <Border Classes="join-card"
                      IsVisible="{Binding IsVisible}">

                <Grid RowDefinitions="Auto,Auto,Auto">

                  <!-- Row 1: Join type badge + table pair -->
                  <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6">

                    <!-- JOIN type badge -->
                    <Border Grid.Column="0"
                            Background="#0F1A2E"
                            BorderBrush="#1E3A60"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="5,2"
                            Margin="0,0,8,0">
                      <TextBlock Text="{Binding JoinType}"
                                 FontSize="10"
                                 FontWeight="Bold"
                                 Foreground="#60A5FA"
                                 FontFamily="Consolas,monospace"/>
                    </Border>

                    <!-- Table pair -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding TablePair}"
                               FontSize="11"
                               Foreground="#C8D0DC"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Confidence badge -->
                    <Border Grid.Column="2"
                            CornerRadius="4"
                            Padding="5,2"
                            Margin="6,0,0,0">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.15"/>
                      </Border.Background>
                      <TextBlock Text="{Binding ConfidenceLabel}"
                                 FontSize="9"
                                 Foreground="{Binding ConfidenceBrush}"/>
                    </Border>
                  </Grid>

                  <!-- Row 2: ON clause -->
                  <Border Grid.Row="1"
                          Background="#0A0D15"
                          CornerRadius="5"
                          Padding="7,4"
                          Margin="0,0,0,8">
                    <TextBlock Text="{Binding OnClause}"
                               FontFamily="Consolas,monospace"
                               FontSize="11"
                               Foreground="#4ADE80"
                               TextTrimming="CharacterEllipsis"/>
                  </Border>

                  <!-- Row 3: Rationale + action buttons -->
                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">

                    <TextBlock Grid.Column="0"
                               Text="{Binding Rationale}"
                               FontSize="10"
                               Foreground="#4A5568"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="1"
                            Classes="accept-btn"
                            Content="✓ Accept"
                            Margin="0,0,4,0"
                            Command="{Binding AcceptCommand}"/>

                    <Button Grid.Column="2"
                            Classes="dismiss-btn"
                            Content="Skip"
                            Command="{Binding DismissCommand}"/>
                  </Grid>

                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state (all dismissed or accepted) -->
      <Border Padding="16,12"
              IsVisible="{Binding HasCards, Converter={x:Static BoolConverters.Not}}">
        <TextBlock Text="All suggestions handled"
                   FontSize="12"
                   Foreground="#4A5568"
                   HorizontalAlignment="Center"/>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
