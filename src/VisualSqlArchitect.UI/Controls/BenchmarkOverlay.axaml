<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.BenchmarkOverlay"
             x:DataType="vm:BenchmarkViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="Foreground" Value="#6B7A99"/>
      <Setter Property="Margin"     Value="0,0,0,4"/>
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="Background"      Value="#0D0F14"/>
      <Setter Property="BorderBrush"     Value="#252C3F"/>
      <Setter Property="Foreground"      Value="#C8D0DC"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Padding"         Value="7,5"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background"      Value="#3B82F6"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="Padding"         Value="12,7"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background"      Value="#1A1E2C"/>
      <Setter Property="Foreground"      Value="#C8D0DC"/>
      <Setter Property="Padding"         Value="10,7"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderBrush"     Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Border.stat-card">
      <Setter Property="Background"      Value="#0D0F14"/>
      <Setter Property="BorderBrush"     Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="8"/>
      <Setter Property="Padding"         Value="12,10"/>
    </Style>
    <Style Selector="Border.hist-row">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding"      Value="8,5"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.07"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.hist-row:pointerover">
      <Setter Property="Background" Value="#1A1E2C"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Benchmark overlay card ═══════════════════════════════════════════════ -->
  <Border Width="680"
          MaxHeight="620"
          CornerRadius="14"
          Background="#13161F"
          BorderBrush="#252C3F"
          BorderThickness="1"
          BoxShadow="0 24 64 0 #AA000000">

    <Grid RowDefinitions="Auto,*">

      <!-- Header -->
      <Border Grid.Row="0" BorderBrush="#1E2335" BorderThickness="0,0,0,1" Padding="20,14">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="30" Height="30" CornerRadius="8"
                    Background="#0F1A30" BorderBrush="#1E3A60" BorderThickness="1">
              <mi:MaterialIcon Kind="TimerOutline" Width="16" Height="16" Foreground="#3B82F6"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="1">
              <TextBlock Text="Query Benchmark" FontSize="15" FontWeight="SemiBold" Foreground="#C8D0DC"/>
              <TextBlock Text="Measures avg / median / p95 latency over N iterations"
                         FontSize="10" Foreground="#4A5568"/>
            </StackPanel>
          </StackPanel>

          <Button Grid.Column="2" Classes="secondary" Command="{Binding CloseCommand}"
                  Width="28" Height="28" Padding="0"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="Close (Esc)"
                  AutomationProperties.Name="Close benchmark">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Body -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <Border Padding="20,16">
          <StackPanel Spacing="16">

            <!-- SQL preview (read-only) -->
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="SQL being benchmarked"/>
              <Border Background="#0D0F14" BorderBrush="#252C3F" BorderThickness="1"
                      CornerRadius="6" Padding="10,8">
                <TextBlock Text="{Binding Sql}" FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="11" Foreground="#60A5FA" TextWrapping="Wrap"
                           MaxLines="4" TextTrimming="CharacterEllipsis"/>
              </Border>
            </StackPanel>

            <!-- Config row -->
            <Grid ColumnDefinitions="*,12,*,12,*,12,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="Run label"/>
                <TextBox Classes="field" Text="{Binding RunLabel}" Watermark="Run 1"/>
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="label" Text="Iterations (1–100)"/>
                <TextBox Classes="field" Text="{Binding Iterations}" Watermark="10"/>
              </StackPanel>
              <StackPanel Grid.Column="4">
                <TextBlock Classes="label" Text="Warm-up passes (0–10)"/>
                <TextBox Classes="field" Text="{Binding WarmupIterations}" Watermark="2"/>
              </StackPanel>
              <StackPanel Grid.Column="6">
                <TextBlock Classes="label" Text="Interval between runs (ms)"/>
                <TextBox Classes="field" Text="{Binding IntervalMs}" Watermark="0"/>
              </StackPanel>
            </Grid>

            <!-- Progress bar -->
            <StackPanel Spacing="5" IsVisible="{Binding IsRunning}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Progress}"
                           FontSize="11" Foreground="#6B7A99"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#4A5568">
                  <Run Text="{Binding ProgressFraction, StringFormat={}{0:P0}}"/>
                </TextBlock>
              </Grid>
              <ProgressBar Value="{Binding ProgressFraction}"
                           Minimum="0" Maximum="1"
                           Height="4" CornerRadius="2"
                           Foreground="#3B82F6" Background="#1E2335"/>
            </StackPanel>

            <!-- Non-running status -->
            <TextBlock Text="{Binding Progress}" FontSize="11" Foreground="#6B7A99"
                       IsVisible="{Binding !IsRunning}"
                       IsEnabled="{Binding Progress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="primary" Command="{Binding RunCommand}"
                      AutomationProperties.Name="Run benchmark">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="Play" Width="14" Height="14"
                                   IsVisible="{Binding !IsRunning}"/>
                  <mi:MaterialIcon Kind="Loading" Width="14" Height="14"
                                   IsVisible="{Binding IsRunning}"/>
                  <TextBlock Text="Run Benchmark" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button Classes="secondary" Command="{Binding CancelCommand}"
                      IsVisible="{Binding IsRunning}"
                      AutomationProperties.Name="Cancel benchmark">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="Stop" Width="14" Height="14"/>
                  <TextBlock Text="Cancel" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button Classes="secondary" Command="{Binding ClearHistoryCommand}"
                      IsVisible="{Binding HasResult}"
                      AutomationProperties.Name="Clear history">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="DeleteSweep" Width="13" Height="13"/>
                  <TextBlock Text="Clear History" FontSize="12"/>
                </StackPanel>
              </Button>
            </StackPanel>

            <!-- Latest result stats -->
            <StackPanel IsVisible="{Binding HasResult}" Spacing="10">
              <TextBlock Text="LATEST RESULT" FontSize="9" FontWeight="SemiBold"
                         Foreground="#4A5568" LetterSpacing="1"/>

              <Grid ColumnDefinitions="*,8,*,8,*,8,*,8,*">
                <!-- Avg -->
                <Border Grid.Column="0" Classes="stat-card">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="AVG" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A5568" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Light" Foreground="#C8D0DC"
                               HorizontalAlignment="Center">
                      <Run Text="{Binding LatestResult.AvgMs, StringFormat={}{0:0.0}}"/>
                    </TextBlock>
                    <TextBlock Text="ms" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Median -->
                <Border Grid.Column="2" Classes="stat-card">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="MEDIAN" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A5568" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Light" Foreground="#C8D0DC"
                               HorizontalAlignment="Center">
                      <Run Text="{Binding LatestResult.MedianMs, StringFormat={}{0:0.0}}"/>
                    </TextBlock>
                    <TextBlock Text="ms" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- P95 -->
                <Border Grid.Column="4" Classes="stat-card">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="P95" FontSize="9" FontWeight="SemiBold"
                               Foreground="#FBBF24" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Light" Foreground="#FBBF24"
                               HorizontalAlignment="Center">
                      <Run Text="{Binding LatestResult.P95Ms, StringFormat={}{0:0.0}}"/>
                    </TextBlock>
                    <TextBlock Text="ms" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Min -->
                <Border Grid.Column="6" Classes="stat-card">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="MIN" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4ADE80" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Light" Foreground="#4ADE80"
                               HorizontalAlignment="Center">
                      <Run Text="{Binding LatestResult.MinMs, StringFormat={}{0:0.0}}"/>
                    </TextBlock>
                    <TextBlock Text="ms" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Max -->
                <Border Grid.Column="8" Classes="stat-card">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="MAX" FontSize="9" FontWeight="SemiBold"
                               Foreground="#EF4444" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Light" Foreground="#EF4444"
                               HorizontalAlignment="Center">
                      <Run Text="{Binding LatestResult.MaxMs, StringFormat={}{0:0.0}}"/>
                    </TextBlock>
                    <TextBlock Text="ms" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Iterations info -->
              <TextBlock FontSize="10" Foreground="#4A5568">
                <Run Text="{Binding LatestResult.Iterations}"/>
                <Run Text=" iterations · run at "/>
                <Run Text="{Binding LatestResult.RunAt, StringFormat={}{0:HH:mm:ss}}"/>
              </TextBlock>
            </StackPanel>

            <!-- History table -->
            <StackPanel IsVisible="{Binding HasResult}" Spacing="8">
              <TextBlock Text="HISTORY" FontSize="9" FontWeight="SemiBold"
                         Foreground="#4A5568" LetterSpacing="1"/>

              <!-- Column headers -->
              <Grid ColumnDefinitions="*,70,70,70,70,70,80">
                <TextBlock Grid.Column="0" Text="Label" Classes="label" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="1" Text="Avg" Classes="label" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="2" Text="Median" Classes="label" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="3" Text="P95" Classes="label" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="Min" Classes="label" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="5" Text="Max" Classes="label" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="6" Text="N" Classes="label" HorizontalAlignment="Right" Margin="0,0,8,0"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:BenchmarkRunResult">
                    <Border Classes="hist-row">
                      <Grid ColumnDefinitions="*,70,70,70,70,70,80">
                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                   FontSize="11" Foreground="#C8D0DC"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#C8D0DC"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                          <Run Text="{Binding AvgMs, StringFormat={}{0:0.0}}"/>
                          <Run Text="ms" Foreground="#4A5568"/>
                        </TextBlock>
                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#C8D0DC"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                          <Run Text="{Binding MedianMs, StringFormat={}{0:0.0}}"/>
                          <Run Text="ms" Foreground="#4A5568"/>
                        </TextBlock>
                        <TextBlock Grid.Column="3" FontSize="11" Foreground="#FBBF24"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                          <Run Text="{Binding P95Ms, StringFormat={}{0:0.0}}"/>
                          <Run Text="ms" Foreground="#4A5568"/>
                        </TextBlock>
                        <TextBlock Grid.Column="4" FontSize="11" Foreground="#4ADE80"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                          <Run Text="{Binding MinMs, StringFormat={}{0:0.0}}"/>
                          <Run Text="ms" Foreground="#4A5568"/>
                        </TextBlock>
                        <TextBlock Grid.Column="5" FontSize="11" Foreground="#EF4444"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                          <Run Text="{Binding MaxMs, StringFormat={}{0:0.0}}"/>
                          <Run Text="ms" Foreground="#4A5568"/>
                        </TextBlock>
                        <TextBlock Grid.Column="6" FontSize="11" Foreground="#6B7A99"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                          <Run Text="{Binding Iterations}"/>
                          <Run Text=" iters"/>
                        </TextBlock>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

          </StackPanel>
        </Border>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
