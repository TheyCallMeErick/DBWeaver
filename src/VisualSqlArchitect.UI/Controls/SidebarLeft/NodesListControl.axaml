<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.NodesListControl"
             x:DataType="vm:NodesListViewModel"
             Background="#0D0F14">

  <UserControl.Styles>
    <Style Selector="TextBlock.group-header">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#D1D5DB"/>
      <Setter Property="Margin" Value="12,12,12,6"/>
    </Style>

    <Style Selector="Border.node-card">
      <Setter Property="Background" Value="#11161F"/>
      <Setter Property="BorderBrush" Value="#1E2335"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
          <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.node-card:pointerover">
      <Setter Property="Background" Value="#1A202D"/>
      <Setter Property="BorderBrush" Value="#2D3B52"/>
    </Style>

    <Style Selector="Border.node-card.selected">
      <Setter Property="Background" Value="#1F3A54"/>
      <Setter Property="BorderBrush" Value="#3B6B9F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Button.node-card-button">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.node-card-button:pointerover Border.node-card">
      <Setter Property="Background" Value="#1A202D"/>
      <Setter Property="BorderBrush" Value="#2D3B52"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Search Bar -->
    <Border Grid.Row="0"
            Background="#0B0E15"
            BorderBrush="#1E2335"
            BorderThickness="0,0,0,1"
            Padding="10,8,10,8">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <mi:MaterialIcon Grid.Column="0"
                         Kind="Magnify"
                         Foreground="#6B7280"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         Width="18"
                         Height="18"/>
        <TextBox Grid.Column="1"
                 Text="{Binding SearchQuery}"
                 Watermark="{Binding [nodesList.search], Source={x:Static loc:LocalizationService.Instance}}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="#D1D5DB"
                 Padding="4,0,0,0"
                 FontSize="12"/>
        <Button Grid.Column="2"
                Content="✕"
                IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Command="{Binding ClearSearchCommand}"
                Background="Transparent"
                Foreground="#6B7280"
                Padding="4,2"
                Margin="6,0,0,0"
                FontSize="14"/>
      </Grid>
    </Border>

    <!-- Groups and Items Scroller -->
    <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto"
                  Theme="{StaticResource FluentScrollViewer}">
      <StackPanel Margin="0,0,0,8">
        <ItemsControl ItemsSource="{Binding FilteredGroups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:NodeTypeGroupViewModel">
              <StackPanel Spacing="0">
                <!-- Group Header with category color -->
                <Grid Margin="12,12,12,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <!-- Category indicator dot + name -->
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Name}"
                               Foreground="{Binding Color}"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                  </StackPanel>

                  <!-- Count -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding Count}"
                             Foreground="#6B7280"
                             FontSize="10"
                             VerticalAlignment="Center"/>
                </Grid>

                <!-- Items Grid (Wrapping layout) -->
                <ItemsControl ItemsSource="{Binding Items}"
                              IsVisible="{Binding IsExpanded}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" Margin="8,0,8,6"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>

                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:NodeTypeItemViewModel">
                      <Button Classes="node-card-button"
                              Command="{Binding SpawnNodeCommand}"
                              Width="110"
                              Margin="4,4"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0">
                        <Border Classes="node-card" Padding="10,8">
                        <StackPanel Spacing="6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                          <!-- Icon -->
                          <mi:MaterialIcon Kind="FunctionVariant"
                                          Foreground="#60A5FA"
                                          Width="24"
                                          Height="24"
                                          HorizontalAlignment="Center"/>

                          <!-- Title -->
                          <TextBlock Text="{Binding Title}"
                                     Foreground="#E5E7EB"
                                     FontWeight="Medium"
                                     FontSize="12"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"/>

                          <!-- Subtitle -->
                          <TextBlock Text="{Binding Subtitle}"
                                     Foreground="#9CA3AF"
                                     FontSize="9"
                                     TextAlignment="Center"
                                     Opacity="0.7"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
