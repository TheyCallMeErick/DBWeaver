<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:ctrl="using:VisualSqlArchitect.UI.Controls"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             x:Class="VisualSqlArchitect.UI.Controls.ConnectionTabControl"
             x:DataType="vm:ConnectionManagerViewModel"
             Background="#0D0F14"
             Name="ConnTabControl">

  <Grid RowDefinitions="Auto,*,Auto" Margin="10">

    <!-- Active Connection Section -->
    <StackPanel Grid.Row="0" Spacing="8">
      <TextBlock Text="{Binding [connectionTab.active], Source={x:Static loc:LocalizationService.Instance}}"
                 FontSize="10"
                 FontWeight="SemiBold"
                 Foreground="#6B7280"
                 Margin="2,0,0,0"
                 Opacity="0.8"/>

      <Border Background="#11161F"
              BorderBrush="#1E2335"
              BorderThickness="1"
              CornerRadius="7"
              Padding="12,10"
              Cursor="Hand"
              IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Health dot -->
          <Ellipse Grid.Column="0"
                   Width="8"
                   Height="8"
                   Fill="{Binding ConnectionIndicatorColor}"
                   VerticalAlignment="Center"/>

          <!-- Provider and database -->
          <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding ActiveConnectionLabel}"
                       Foreground="#E5E7EB"
                       FontWeight="Medium"
                       FontSize="12"/>
            <TextBlock Text="{Binding ConnectionHealthLabel}"
                       Foreground="#9CA3AF"
                       FontSize="10"
                       Margin="0,1,0,0"
                       ToolTip.Tip="{Binding ConnectionHealthTooltip}"/>
          </StackPanel>

          <!-- Refresh button -->
          <Button Grid.Column="2"
                  Content="↻"
                  Command="{Binding RefreshHealthCommand}"
                  Background="#1A3A54"
                  Foreground="#60A5FA"
                  Padding="8,5"
                  FontSize="10"
                  CornerRadius="5"
                  BorderThickness="0"
                  Margin="6,0,0,0"/>
        </Grid>
      </Border>

      <!-- No connection state -->
      <Border Background="#11161F"
              BorderBrush="#1E2335"
              BorderThickness="1"
              CornerRadius="7"
              Padding="12,10"
              IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNullOrEmpty}}">
        <TextBlock Text="{Binding [connectionTab.none], Source={x:Static loc:LocalizationService.Instance}}"
                   Foreground="#9CA3AF"
                   FontSize="11"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>
    </StackPanel>

    <!-- Saved Connections Section -->
    <StackPanel Grid.Row="1" Spacing="8" Margin="0,12,0,0">
      <TextBlock Text="{Binding [connectionTab.saved], Source={x:Static loc:LocalizationService.Instance}}"
                 FontSize="10"
                 FontWeight="SemiBold"
                 Foreground="#6B7280"
                 Margin="2,0,0,0"
                 Opacity="0.8"/>

      <ScrollViewer VerticalScrollBarVisibility="Auto" Theme="{StaticResource FluentScrollViewer}">
        <ItemsControl ItemsSource="{Binding Profiles}" Margin="0,0,4,0" Name="ProfilesItemsControl">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="6"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>

          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ConnectionProfile">
              <Border Background="#11161F"
                      BorderBrush="#1E2335"
                      BorderThickness="1"
                      CornerRadius="7"
                      Padding="12,10"
                      Cursor="Hand">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Status dot -->
                  <Ellipse Grid.Column="0"
                           Width="8"
                           Height="8"
                           VerticalAlignment="Center"
                           Fill="#6B7280"
                           Name="StatusDot"/>

                  <!-- Provider and database name -->
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding Provider}" Foreground="#D1D5DB" FontSize="11" FontWeight="Medium"/>
                    <TextBlock Text="·" Foreground="#9CA3AF" FontSize="11"/>
                    <TextBlock Text="{Binding Database}" Foreground="#D1D5DB" FontSize="11"/>
                  </StackPanel>

                  <!-- Connect/Disconnect button -->
                  <Button Grid.Column="2"
                          Padding="8,5"
                          FontSize="10"
                          CornerRadius="5"
                          BorderThickness="0"
                          Margin="6,0,0,0"
                          Command="{Binding ProfileActionCommand, RelativeSource={RelativeSource AncestorType=ctrl:ConnectionTabControl}}"
                          CommandParameter="{Binding .}"
                          Name="ActionButton"
                                                    Content="{Binding [connection.connect], Source={x:Static loc:LocalizationService.Instance}}"
                          Background="#4C1F6B"
                          Foreground="#C084FC"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </StackPanel>

    <!-- New Connection Button -->
    <Button Grid.Row="2"
            Content="{Binding [connectionTab.new], Source={x:Static loc:LocalizationService.Instance}}"
            Background="#1A3A54"
            Foreground="#60A5FA"
            Padding="12,8"
            HorizontalAlignment="Stretch"
            Margin="0,12,0,0"
            CornerRadius="6"
            BorderThickness="0"
            FontSize="11"
            FontWeight="Medium"
            Command="{Binding NewProfileCommand}"/>
  </Grid>

</UserControl>
