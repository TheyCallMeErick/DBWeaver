<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             x:Class="VisualSqlArchitect.UI.Controls.SearchMenuControl"
             x:DataType="vm:SearchMenuViewModel">

  <UserControl.Styles>
    <!-- Result item default -->
    <Style Selector="Border.result-item">
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="CornerRadius"  Value="8"/>
      <Setter Property="Padding"       Value="10,7"/>
      <Setter Property="Margin"        Value="4,1"/>
      <Setter Property="Cursor"        Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.result-item:pointerover">
      <Setter Property="Background" Value="#1E2335"/>
    </Style>
    <Style Selector="Border.result-item.selected">
      <Setter Property="Background" Value="#1A2845"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Floating panel ═════════════════════════════════════════════════════ -->
  <Border Width="340"
          CornerRadius="12"
          Background="#13161F"
          BorderBrush="#252C3F"
          BorderThickness="1"
          BoxShadow="0 8 40 0 #80000000, 0 2 8 0 #60000000">

    <StackPanel>

      <!-- ── Search input ──────────────────────────────────────────────────── -->
      <Border Background="#1A1E2C"
              CornerRadius="12,12,0,0"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Search icon -->
          <Border Grid.Column="0"
                  Width="18" Height="18"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
            <Path Data="M 11 2 A 9 9 0 1 0 11 20 A 9 9 0 1 0 11 2 Z M 20 20 L 15.5 15.5"
                  Stroke="#60A5FA"
                  StrokeThickness="1.8"
                  StrokeLineCap="Round"
                  Stretch="Uniform"/>
          </Border>

          <!-- Text input -->
          <TextBox Grid.Column="1"
                   Text="{Binding Query, Mode=TwoWay}"
                   Watermark="Search nodes… (Esc to close)"
                   FontSize="13"
                   Background="Transparent"
                   BorderThickness="0"
                   CaretBrush="#60A5FA"
                   Foreground="#E8EAED"
                   Name="SearchInput">
            <TextBox.Styles>
              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                <Setter Property="BorderBrush" Value="Transparent"/>
              </Style>
            </TextBox.Styles>
          </TextBox>

          <!-- Keyboard shortcut badge -->
          <Border Grid.Column="2"
                  Background="#252C3F"
                  CornerRadius="4"
                  Padding="5,2"
                  VerticalAlignment="Center">
            <TextBlock Text="⇧A"
                       FontSize="10"
                       Foreground="#4A5568"/>
          </Border>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Results list ───────────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Results}" Margin="0,4,0,4">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:NodeSearchResultViewModel">

              <Border Classes="result-item">

                <Grid ColumnDefinitions="34,*,Auto">

                  <!-- Category icon badge -->
                  <Border Grid.Column="0"
                          Width="28" Height="28"
                          CornerRadius="7"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding AccentColor}" Opacity="0.18"/>
                    </Border.Background>
                    <TextBlock Text="{Binding Icon}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{Binding AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                  </Border>

                  <!-- Name + category -->
                  <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#E8EAED"/>
                    <TextBlock Text="{Binding Category}"
                               FontSize="10"
                               Foreground="#4A5568"/>
                  </StackPanel>

                  <!-- Accent dot -->
                  <Ellipse Grid.Column="2"
                           Width="6" Height="6"
                           Fill="{Binding AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state -->
      <Border Padding="16,20"
              IsVisible="{Binding Results.Count, Converter={x:Static BoolConverters.Not}}">
        <StackPanel HorizontalAlignment="Center" Spacing="6">
          <TextBlock Text="No nodes found"
                     FontSize="13"
                     Foreground="#4A5568"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Try searching for UPPER, JSON, CAST, AND…"
                     FontSize="10"
                     Foreground="#2D3748"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- ── Footer keyboard hints ─────────────────────────────────────────── -->
      <Border Background="#0E1018"
              CornerRadius="0,0,12,12"
              Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↑↓" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="Navigate" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↵" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="Spawn" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="Esc" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="Close" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
