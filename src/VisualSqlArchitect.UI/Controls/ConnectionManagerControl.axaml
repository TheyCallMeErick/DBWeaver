<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.ConnectionManagerControl"
             x:DataType="vm:ConnectionManagerViewModel">

  <UserControl.Styles>
    <!-- List item hover -->
    <Style Selector="ListBoxItem">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="Padding"      Value="10,8"/>
      <Setter Property="Margin"       Value="4,2"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#1E2D4A"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1A1E2C"/>
    </Style>
    <!-- Form labels -->
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="Foreground" Value="#6B7A99"/>
      <Setter Property="Margin"     Value="0,0,0,4"/>
    </Style>
    <!-- Form input fields -->
    <Style Selector="TextBox.field">
      <Setter Property="Background"      Value="#0D0F14"/>
      <Setter Property="BorderBrush"     Value="#252C3F"/>
      <Setter Property="Foreground"      Value="#C8D0DC"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Padding"         Value="8,6"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <!-- Button variants -->
    <Style Selector="Button.primary">
      <Setter Property="Background"      Value="#3B82F6"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="Padding"         Value="12,7"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background"      Value="#1A1E2C"/>
      <Setter Property="Foreground"      Value="#C8D0DC"/>
      <Setter Property="Padding"         Value="12,7"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderBrush"     Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#EF4444"/>
      <Setter Property="Padding"         Value="8,7"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderBrush"     Value="#EF4444"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Connection Manager overlay card ══════════════════════════════════════ -->
  <Border Width="780"
          MaxHeight="560"
          CornerRadius="14"
          Background="#13161F"
          BorderBrush="#252C3F"
          BorderThickness="1"
          BoxShadow="0 24 64 0 #AA000000">

    <Grid RowDefinitions="Auto,Auto,*">

      <!-- Header -->
      <Border Grid.Row="0" BorderBrush="#1E2335" BorderThickness="0,0,0,1" Padding="20,14">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="30" Height="30" CornerRadius="8"
                    Background="#0F1A30" BorderBrush="#1E3A60" BorderThickness="1">
              <mi:MaterialIcon Kind="DatabaseSettings" Width="16" Height="16" Foreground="#3B82F6"/>
            </Border>
            <TextBlock Text="Connection Manager"
                       FontSize="15" FontWeight="SemiBold" Foreground="#C8D0DC"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <Button Grid.Column="2" Classes="secondary" Command="{Binding CloseCommand}"
                  Width="28" Height="28" Padding="0"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="Close (Esc)"
                  AutomationProperties.Name="Close connection manager">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Active connection health banner -->
      <Border Grid.Row="1" BorderBrush="#1E2335" BorderThickness="0,0,0,1"
              Background="#0D0F14" Padding="20,8">
        <Grid ColumnDefinitions="Auto,*,Auto,8,Auto">
          <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,8,0"
                   Fill="{Binding ConnectionIndicatorColor}"/>
          <TextBlock Grid.Column="1" FontSize="11" Foreground="#6B7A99" VerticalAlignment="Center">
            <Run Text="{Binding ActiveConnectionLabel}"/>
            <Run Text=" — "/>
            <Run Text="{Binding ConnectionHealthLabel}" Foreground="{Binding ConnectionIndicatorColor}"/>
          </TextBlock>
          <TextBlock Grid.Column="2" Text="ACTIVE" FontSize="9" FontWeight="SemiBold"
                     Foreground="#4A5568" VerticalAlignment="Center" LetterSpacing="1"
                     IsVisible="{Binding ActiveProfileId, Converter={x:Static ObjectConverters.IsNotNull}}"/>
          <Button Grid.Column="4" Classes="secondary" Command="{Binding RefreshHealthCommand}"
                  Padding="6,4" ToolTip.Tip="Re-check connection health"
                  AutomationProperties.Name="Refresh health">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <mi:MaterialIcon Kind="Refresh" Width="11" Height="11"/>
              <TextBlock Text="Ping" FontSize="10"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- Body -->
      <Grid Grid.Row="2" ColumnDefinitions="220,*">

        <!-- LEFT column: saved connections list -->
        <Border Grid.Column="0" BorderBrush="#1E2335" BorderThickness="0,0,1,0" Padding="8,10">
          <Grid RowDefinitions="Auto,*,Auto">

            <TextBlock Grid.Row="0"
                       Text="SAVED CONNECTIONS"
                       FontSize="9" FontWeight="SemiBold" Foreground="#4A5568"
                       Margin="8,0,0,8" LetterSpacing="1"/>

            <!-- Connection list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionProfile">
                  <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="●" FontSize="8" Foreground="#3B82F6"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#C8D0DC"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock FontSize="10" Foreground="#4A5568" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding Provider}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Database}"/>
                      </TextBlock>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- New connection button -->
            <Button Grid.Row="2" Classes="secondary" Command="{Binding NewProfileCommand}"
                    HorizontalAlignment="Stretch" Margin="4,8,4,4">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="Plus" Width="13" Height="13"/>
                <TextBlock Text="New Connection" FontSize="11"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <!-- RIGHT column: edit form -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
          <Border Padding="20,16">
          <StackPanel Spacing="0">

            <!-- Placeholder when nothing is selected -->
            <StackPanel IsVisible="{Binding !IsEditing}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,60,0,0" Spacing="10">
              <mi:MaterialIcon Kind="DatabaseOff" Width="40" Height="40"
                               Foreground="#252C3F" HorizontalAlignment="Center"/>
              <TextBlock Text="Select a connection or create a new one"
                         FontSize="12" Foreground="#4A5568" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Edit form -->
            <StackPanel IsVisible="{Binding IsEditing}" Spacing="0">

              <!-- Connection name -->
              <TextBlock Classes="label" Text="Connection Name"/>
              <TextBox Classes="field" Text="{Binding EditName}" Margin="0,0,0,12"
                       Watermark="My Production DB"/>

              <!-- Provider -->
              <TextBlock Classes="label" Text="Provider"/>
              <ComboBox ItemsSource="{x:Static vm:ConnectionManagerViewModel.AvailableProviders}"
                        SelectedItem="{Binding EditProvider}"
                        Background="#0D0F14" BorderBrush="#252C3F" Foreground="#C8D0DC"
                        FontSize="12" Padding="8,4" CornerRadius="6"
                        HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

              <!-- Host + Port -->
              <Grid ColumnDefinitions="*,12,100" Margin="0,0,0,12">
                <StackPanel Grid.Column="0">
                  <TextBlock Classes="label" Text="Host"/>
                  <TextBox Classes="field" Text="{Binding EditHost}" Watermark="localhost"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Classes="label" Text="Port"/>
                  <TextBox Classes="field" Text="{Binding EditPort}" Watermark="5432"/>
                </StackPanel>
              </Grid>

              <!-- Database -->
              <TextBlock Classes="label" Text="Database"/>
              <TextBox Classes="field" Text="{Binding EditDatabase}" Margin="0,0,0,12"
                       Watermark="database_name"/>

              <!-- Username + Password -->
              <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,12">
                <StackPanel Grid.Column="0">
                  <TextBlock Classes="label" Text="Username"/>
                  <TextBox Classes="field" Text="{Binding EditUsername}" Watermark="user"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Classes="label" Text="Password"/>
                  <TextBox Classes="field" Text="{Binding EditPassword}"
                           PasswordChar="●" Watermark="••••••••"/>
                </StackPanel>
              </Grid>

              <!-- Timeout -->
              <TextBlock Classes="label" Text="Timeout (seconds)"/>
              <TextBox Classes="field" Text="{Binding EditTimeout}" Margin="0,0,0,16"
                       Watermark="30"/>

              <!-- Test connection status -->
              <Border IsVisible="{Binding TestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      Background="#0D0F14" BorderBrush="#252C3F" BorderThickness="1"
                      CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                <TextBlock Text="{Binding TestStatus}" FontSize="11"
                           Foreground="{Binding TestStatusColor}"
                           TextWrapping="Wrap"/>
              </Border>

              <!-- Action buttons row -->
              <Grid ColumnDefinitions="Auto,*,Auto,8,Auto,8,Auto">

                <!-- Delete (only when editing existing) -->
                <Button Grid.Column="0" Classes="danger"
                        Command="{Binding DeleteProfileCommand}"
                        IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}"
                        ToolTip.Tip="Delete connection"
                        AutomationProperties.Name="Delete connection">
                  <mi:MaterialIcon Kind="Delete" Width="14" Height="14"/>
                </Button>

                <!-- Test -->
                <Button Grid.Column="2" Classes="secondary"
                        Command="{Binding TestConnectionCommand}"
                        ToolTip.Tip="Test connection"
                        AutomationProperties.Name="Test connection">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="LanConnect" Width="13" Height="13"
                                     IsVisible="{Binding !IsTesting}"/>
                    <mi:MaterialIcon Kind="Loading" Width="13" Height="13"
                                     IsVisible="{Binding IsTesting}"/>
                    <TextBlock Text="Test" FontSize="12"/>
                  </StackPanel>
                </Button>

                <!-- Save -->
                <Button Grid.Column="4" Classes="secondary"
                        Command="{Binding SaveProfileCommand}"
                        ToolTip.Tip="Save connection"
                        AutomationProperties.Name="Save connection">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="ContentSave" Width="13" Height="13"/>
                    <TextBlock Text="Save" FontSize="12"/>
                  </StackPanel>
                </Button>

                <!-- Connect -->
                <Button Grid.Column="6" Classes="primary"
                        Command="{Binding ConnectCommand}"
                        ToolTip.Tip="Activate this connection"
                        AutomationProperties.Name="Connect">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="DatabaseArrowRight" Width="13" Height="13"/>
                    <TextBlock Text="Connect" FontSize="12"/>
                  </StackPanel>
                </Button>
              </Grid>

            </StackPanel>
          </StackPanel>
          </Border>
        </ScrollViewer>

      </Grid>
    </Grid>
  </Border>
</UserControl>
