<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.SqlEditor.SqlEditorRightSidebarControl"
             x:Name="Root"
             x:DataType="vm:SqlEditorViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Padding="10"
                ClipToBounds="True">
    <StackPanel Spacing="10">
      <Border Background="{StaticResource Bg2Brush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource RadiusMD}"
              Padding="10"
              ClipToBounds="True">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14"/>
            <TextBlock Text="{Binding [sqlEditor.sidebar.messages], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="{StaticResource FontWeightHeading}"
                       Foreground="{StaticResource AccentPrimaryHoverBrush}"
                       LetterSpacing="1.5"/>
          </StackPanel>

          <TextBlock Text="{Binding LastExecutionMessage}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="{StaticResource FontSizeBody}"
                     TextWrapping="Wrap"/>

          <TextBlock Text="{Binding ExecutionDetailText}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>

          <TextBlock Text="{Binding MessagesEmptyText}"
                     IsVisible="{Binding IsExecutionHistoryEmpty}"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>

          <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

          <TextBlock Text="{Binding ResultSummaryText}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding ExecutionTelemetryText}"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding CompletionTelemetryText}"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding ExecutionTelemetryErrorsText}"
                     Foreground="{StaticResource StatusErrorBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>

          <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

          <StackPanel Spacing="6">
            <TextBlock Text="{Binding [sqlEditor.sidebar.tools], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="{StaticResource FontWeightHeading}"
                       Foreground="{StaticResource AccentPrimaryHoverBrush}"
                       LetterSpacing="1.5"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="{Binding [sqlEditor.tools.explain], Source={x:Static loc:LocalizationService.Instance}}"
                      Padding="10,2"
                      MinHeight="24"
                      FontSize="{StaticResource FontSizeCaption}"
                      IsEnabled="{Binding IsExplainRunning, Converter={x:Static BoolConverters.Not}}"
                      Click="ExplainButton_Click"/>
              <Button Content="{Binding [sqlEditor.tools.benchmark], Source={x:Static loc:LocalizationService.Instance}}"
                      Padding="10,2"
                      MinHeight="24"
                      FontSize="{StaticResource FontSizeCaption}"
                      IsEnabled="{Binding IsBenchmarkRunning, Converter={x:Static BoolConverters.Not}}"
                      Click="BenchmarkButton_Click"/>
              <Button Content="{Binding [common.cancel], Source={x:Static loc:LocalizationService.Instance}}"
                      Padding="10,2"
                      MinHeight="24"
                      FontSize="{StaticResource FontSizeCaption}"
                      IsEnabled="{Binding IsBenchmarkRunning}"
                      Click="BenchmarkCancelButton_Click"/>
            </StackPanel>

            <TextBlock Text="{Binding ExplainSummaryText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ExplainRawOutput}"
                       IsVisible="{Binding HasExplainRawOutput}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{StaticResource FontSizeCaption}"
                       MaxHeight="120"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock Text="{Binding BenchmarkProgressText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding BenchmarkSummaryText}"
                       IsVisible="{Binding HasBenchmarkResult}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{StaticResource Bg2Brush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource RadiusMD}"
              Padding="10"
              ClipToBounds="True">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="History" Width="14" Height="14"/>
            <TextBlock Text="{Binding [sqlEditor.sidebar.history], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="{StaticResource FontWeightHeading}"
                       Foreground="{StaticResource AccentPrimaryHoverBrush}"
                       LetterSpacing="1.5"/>
          </StackPanel>

          <TextBlock Text="{Binding HistoryEmptyText}"
                     IsVisible="{Binding IsExecutionHistoryEmpty}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>

            <Grid ColumnDefinitions="*,Auto"
              IsVisible="{Binding HasExecutionHistory}">
            <TextBox Grid.Column="0"
                 x:Name="HistorySearchTextBox"
                 Watermark="{Binding [sqlEditor.history.searchWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                 Text="{Binding HistorySearchText}"
                 FontSize="{StaticResource FontSizeCaption}"
                 Background="{StaticResource Bg1Brush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderSubtleBrush}"
                 KeyDown="HistorySearchTextBox_KeyDown"/>
            <Button Grid.Column="1"
                Content="{Binding [common.clear], Source={x:Static loc:LocalizationService.Instance}}"
                Padding="10,2"
                MinHeight="24"
                FontSize="{StaticResource FontSizeCaption}"
                Click="ClearHistorySearchButton_Click"/>
            </Grid>

              <TextBlock Text="{Binding [sqlEditor.history.navigationHint], Source={x:Static loc:LocalizationService.Instance}}"
                 IsVisible="{Binding HasExecutionHistory}"
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="{StaticResource FontSizeCaption}"
                 TextWrapping="Wrap"/>

            <Grid ColumnDefinitions="*,Auto"
              IsVisible="{Binding HasExecutionHistory}">
            <TextBlock Grid.Column="0"
                   Text="{Binding HistoryFilterSummaryText}"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="{StaticResource FontSizeCaption}"
                   VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                Content="{Binding ClearHistoryButtonText}"
                Padding="10,2"
                MinHeight="24"
                FontSize="{StaticResource FontSizeCaption}"
                Click="ClearHistoryButton_Click"/>
            </Grid>

          <TextBlock Text="{Binding [sqlEditor.history.noSearchResults], Source={x:Static loc:LocalizationService.Instance}}"
                     IsVisible="{Binding HasHistorySearchNoResults}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeCaption}"
                     TextWrapping="Wrap"/>

          <ListBox ItemsSource="{Binding FilteredExecutionHistory}"
                   IsVisible="{Binding HasFilteredExecutionHistory}"
                   SelectedItem="{Binding SelectedExecutionHistoryEntry}"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,6"
                        Padding="8"
                        Background="{StaticResource Bg1Brush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSM}">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ExecutedAt}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Sql}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{StaticResource FontSizeBody}"
                               TextWrapping="Wrap"
                               MaxHeight="64"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Button Content="{Binding [sqlEditor.history.use], Source={x:Static loc:LocalizationService.Instance}}"
                            HorizontalAlignment="Left"
                            Padding="10,2"
                            MinHeight="24"
                            FontSize="{StaticResource FontSizeCaption}"
                            Click="HistoryUseButton_Click"/>
                          <Button Content="{Binding [sqlEditor.history.copy], Source={x:Static loc:LocalizationService.Instance}}"
                            HorizontalAlignment="Left"
                            Padding="10,2"
                            MinHeight="24"
                            FontSize="{StaticResource FontSizeCaption}"
                            Click="HistoryCopyButton_Click"/>
                          <Button Content="{Binding [sqlEditor.history.run], Source={x:Static loc:LocalizationService.Instance}}"
                            HorizontalAlignment="Left"
                            Padding="10,2"
                            MinHeight="24"
                            FontSize="{StaticResource FontSizeCaption}"
                            Click="HistoryRunButton_Click"/>
                        </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
